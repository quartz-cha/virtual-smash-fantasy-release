<!DOCTYPE html>
<html lang="ja">

<head>
  <%- include component/head.ejs %>
    <link rel="stylesheet" href="<%= rootPath %>css/about.css">
</head>

<body>
  <%- include component/header.ejs %>
    <main>
      <section id="kv">
        <div>
          <h1><%= content.title %></h1>
          <p clas="detail-date"><%= content.date %></p>
          <ul class="content-tags">
            <% for (var i=0; content.tags.length > i; i++) { %>
            <li>#<%= content.tags[i].label %></li>
            <% } %>
          </ul>
        </div>
      </section>
      <section class="detail-main">
        <p><%- content.detail %></p>
      </section>
      <% if (!feedbackDisabled) { %>
      <section class="detail-footer">
        <ul class="feedback-area">
          <li>
            <%- include svg/hand_good.ejs %>
            <p>40</p>
          </li>
          <li>
            <%- include svg/hand_bad.ejs %>
            <p>3</p>
          </li>
        </ul>
        <div class="comment-area">
          <div class="comment-area-header">
            <h2><span>1</span>件のコメント</h2>
            <select>
              <option>評価順</option>
              <option>新着順</option>
              <option>返信数順</option>
            </select>
          </div>
          <div class="comment-input">
            <div class="comment-userimg">
              <img src="../img/mini-quartz.png">
            </div>
            <div class="comment-input-body">
              <input type="text" placeholder="コメントする...">
              <div class="comment-input-footer">
                <button>キャンセル</button>
                <button>コメント</button>
              </div>
            </div>
          </div>
          <ul>
            <li>
              <div class="comment-userimg">
                <img src="../img/mini-quartz.png">
              </div>
              <div class="comment-body">
                <div class="comment-body-header">
                  <p class="comment-username">おぱーる</p>
                  <p class="comment-date">1時間前</p>
                </div>
                <div class="comment-body-body"><p>変なイラストですね。描いていて恥ずかしくないんですか？</p></div>
                <div class="comment-body-footer">
                  <ul class="feedback-area">
                    <li>
                      <%- include svg/hand_good.ejs %>
                      <p>2</p>
                    </li>
                    <li>
                      <%- include svg/hand_bad.ejs %>
                      <p>1</p>
                    </li>
                  </ul>
                </div>
              </div>
            </li>
          </ul>
        </div>
      </section>
      <% } %>
    </main>
    <%- include component/footer.ejs %>
</body>

</html>